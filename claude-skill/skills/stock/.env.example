# KR 데이터 소스
DART_API_KEY=your_dart_api_key_here
KRX_API_KEY=your_krx_api_key_here

# US 데이터 소스 (v10 — Phase 1)
# Finnhub — https://finnhub.io/register (무료 60 req/min)
FINNHUB_API_KEY=your_finnhub_api_key_here

# FRED — https://fredaccount.stlouisfed.org/apikeys (무료, 즉시 발급)
FRED_API_KEY=your_fred_api_key_here

# SEC EDGAR — 무료, API키 불필요 대신 User-Agent 필수
# 형식: "사용자이름 email@example.com" (SEC가 연락할 수 있는 실제 정보)
SEC_EDGAR_USER_AGENT=Your Name you@example.com
