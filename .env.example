# ========================================
# Stock Manger — Environment Variables
# ========================================
# 로컬: cp .env.example .env 후 값 채움
# Railway: Dashboard → Variables 에 직접 등록

# ---- Database ----
DATABASE_URL=postgresql://stock:stock@localhost:5432/stock_manger
# Railway는 자동 주입: ${{Postgres.DATABASE_URL}}

# ---- App ----
APP_ENV=development            # development | production
# 운영 사용자 UUID — MCP stdio / jobs / dev fallback 용 singleton.
# FastAPI 는 OAuth email → DB users 테이블에서 user_id lookup (이 값은 dev 모드 또는 MCP 단일유저 컨텍스트에서만 사용).
# legacy: DEFAULT_USER_ID 도 인식되지만 신규 배포는 STOCK_USER_ID 사용.
STOCK_USER_ID=
API_KEY=                        # (deprecated, 향후 제거) 로컬 더미 인증

# ---- MCP transport ----
# 로컬: stdio (Claude Code 가 자식 프로세스로 spawn — auth 불필요)
# Railway: streamable-http (또는 http) — Google OAuth 자동 활성화
STOCK_MCP_TRANSPORT=stdio       # stdio | streamable-http | http
MCP_HOST=0.0.0.0
MCP_PORT=8001
# Railway 배포 시: 본 서비스의 public URL. OAuth Discovery issuer 로 사용.
# 예: https://stock-mcp.up.railway.app
MCP_BASE_URL=

# ---- Google OAuth (FastAPI + MCP 공유 IdP) ----
# https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client (Web)
# Authorized redirect URIs 에 다음 추가 필수:
#   https://claude.ai/api/mcp/auth_callback
#   https://claude.ai/api/auth/callback
#   https://<your-vercel-domain>           (v21g 웹 로그인용)
#   http://localhost:5173                  (로컬 웹 개발용)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# 접근 허용 이메일 (콤마 분리). 비어있으면 모두 거부 (보안 기본값).
ALLOWED_EMAILS=

# ---- CORS (FastAPI) ----
# Vercel/커스텀 도메인 origin (콤마 분리). localhost 는 자동 허용.
# 예: ALLOWED_ORIGINS=https://stockclaude.vercel.app
ALLOWED_ORIGINS=
# Vercel preview 와일드카드 (정규식). 예:
# ALLOWED_ORIGIN_REGEX=^https://stockclaude(-[a-z0-9-]+)?\.vercel\.app$
ALLOWED_ORIGIN_REGEX=

# ---- 한국투자증권 Open API (KIS Developers) ----
# https://apiportal.koreainvestment.com 에서 발급
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=                 # 계좌번호 8자리 + 상품코드 2자리
KIS_ENV=real                    # real | paper (모의투자)

# ---- KRX OpenAPI (공매도·시총·종목마스터) ----
# http://openapi.krx.co.kr
KRX_API_KEY=

# ---- DART OpenAPI (공시·재무제표) ----
# https://opendart.fss.or.kr
DART_API_KEY=

# ---- FRED (US 거시지표) ----
# https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ---- Finnhub (US 실적 캘린더) ----
FINNHUB_API_KEY=

# ---- SEC EDGAR (US 공시) ----
# 본인 이름과 이메일로 User-Agent 식별 (키 아님)
SEC_EDGAR_USER_AGENT=your-name your-email@example.com

# ---- Anthropic (서버 AI 필요 시, 현재 Phase 1에선 미사용) ----
# ANTHROPIC_API_KEY=
